/* ============================================================
   VagaCerta — Guia de Estudo
   Estética: sinalética / wayfinding de parque de estacionamento
   ============================================================ */

:root {
  /* Cores — sinalética de estacionamento */
  --asphalt:      #15171C;   /* asfalto profundo */
  --asphalt-2:    #1E222B;   /* superfície escura elevada */
  --asphalt-3:    #2A2F3A;   /* linhas/bordas sobre escuro */
  --park-blue:    #0E5AE6;   /* azul da placa "P" */
  --park-blue-2:  #0B47B4;
  --marking:      #FFC53D;   /* amarelo de marcação rodoviária */
  --marking-2:    #FFD66E;
  --paper:        #F6F4EE;   /* superfície de leitura */
  --paper-2:      #EDE9DF;   /* cartões */
  --paper-line:   #DcD6C8;
  --ink:          #1A1C22;   /* texto principal */
  --mute:         #5C6472;   /* texto secundário */
  --mute-2:       #8A91A0;
  --ok:           #1C9D63;   /* sessão concluída */
  --stop:         #D8442B;   /* sessão cancelada */

  --cat-norman:       #0E5AE6;
  --cat-shneiderman:  #7A3FF2;
  --cat-nielsen:      #1C9D63;
  --cat-visual:       #E0742A;

  --font-display: "Space Grotesk", system-ui, sans-serif;
  --font-body:    "Hanken Grotesk", system-ui, sans-serif;
  --font-mono:    "Space Mono", ui-monospace, monospace;

  --sidebar-w: 264px;
  --maxw: 880px;
}

* { box-sizing: border-box; }

html { scroll-behavior: smooth; }
@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior: auto; }
}

body {
  margin: 0;
  font-family: var(--font-body);
  color: var(--ink);
  background: var(--paper);
  -webkit-font-smoothing: antialiased;
  line-height: 1.6;
}

a { color: var(--park-blue); }

/* barra de progresso de leitura */
#progress-bar {
  position: fixed;
  top: 0; left: 0;
  height: 3px;
  width: 0%;
  background: var(--marking);
  z-index: 200;
  transition: width .1s linear;
}

/* ============================================================
   SIDEBAR / WAYFINDING
   ============================================================ */

.sidebar {
  position: fixed;
  top: 0; left: 0; bottom: 0;
  width: var(--sidebar-w);
  background: var(--asphalt);
  color: var(--paper);
  padding: 26px 20px 24px;
  display: flex;
  flex-direction: column;
  z-index: 150;
  border-right: 1px solid var(--asphalt-3);
  overflow-y: auto;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 6px;
}
.brand__p {
  width: 42px; height: 42px;
  flex: none;
  background: var(--park-blue);
  color: #fff;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 26px;
  display: grid;
  place-items: center;
  border-radius: 9px;
  box-shadow: inset 0 0 0 2px rgba(255,255,255,.25);
}
.brand__name {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 18px;
  letter-spacing: -.01em;
  line-height: 1.05;
}
.brand__name span { color: var(--marking); }
.brand__sub {
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: .04em;
  color: var(--mute-2);
  text-transform: uppercase;
}

.sidebar__rule {
  border: 0;
  border-top: 1px dashed var(--asphalt-3);
  margin: 18px 0 14px;
}

.nav-eyebrow {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--mute-2);
  margin: 0 0 10px 4px;
}

.nav { display: flex; flex-direction: column; gap: 1px; }

.nav-link {
  position: relative;
  display: flex;
  align-items: center;
  gap: 11px;
  padding: 9px 10px 9px 12px;
  color: #C9CED8;
  text-decoration: none;
  border-radius: 7px;
  font-size: 14px;
  font-weight: 500;
  transition: background .15s, color .15s;
}
.nav-link__num {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--mute-2);
  min-width: 26px;
}
.nav-link:hover { background: var(--asphalt-2); color: #fff; }
.nav-link.is-here { background: var(--asphalt-2); color: #fff; }
.nav-link.is-here .nav-link__num { color: var(--marking); }
.nav-link.is-here::before {
  content: "";
  position: absolute;
  left: -20px; top: 50%;
  transform: translateY(-50%);
  width: 5px; height: 22px;
  background: var(--marking);
  border-radius: 0 4px 4px 0;
}

.sidebar__foot {
  margin-top: auto;
  padding-top: 18px;
  font-family: var(--font-mono);
  font-size: 10.5px;
  color: var(--mute-2);
  line-height: 1.5;
}

/* botão menu mobile */
.nav-toggle {
  display: none;
  position: fixed;
  top: 14px; right: 14px;
  z-index: 160;
  width: 46px; height: 46px;
  border: 0;
  border-radius: 10px;
  background: var(--asphalt);
  cursor: pointer;
  padding: 0;
}
.nav-toggle span,
.nav-toggle span::before,
.nav-toggle span::after {
  content: "";
  display: block;
  position: absolute;
  left: 13px;
  width: 20px; height: 2px;
  background: var(--marking);
  transition: transform .2s, opacity .2s;
}
.nav-toggle span { top: 22px; }
.nav-toggle span::before { top: -6px; }
.nav-toggle span::after { top: 6px; }
.nav-toggle.is-open span { background: transparent; }
.nav-toggle.is-open span::before { transform: translateY(6px) rotate(45deg); }
.nav-toggle.is-open span::after { transform: translateY(-6px) rotate(-45deg); }

/* ============================================================
   LAYOUT PRINCIPAL
   ============================================================ */

.main { margin-left: var(--sidebar-w); }

.section {
  padding: 70px clamp(20px, 5vw, 64px);
  max-width: calc(var(--maxw) + 128px);
}
.section--tight { padding-top: 40px; }

.section__tag {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--park-blue);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 14px;
}
.section__tag::before {
  content: "";
  width: 22px; height: 2px;
  background: var(--park-blue);
}

h2.section__title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(26px, 3.4vw, 38px);
  letter-spacing: -.02em;
  line-height: 1.08;
  margin: 0 0 16px;
  max-width: var(--maxw);
}
.section__intro {
  font-size: 17px;
  color: var(--mute);
  max-width: 60ch;
  margin: 0 0 8px;
}

h3.sub {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 21px;
  letter-spacing: -.01em;
  margin: 44px 0 4px;
  display: flex;
  align-items: baseline;
  gap: 10px;
}
h3.sub .sub__code {
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--mute-2);
  font-weight: 400;
}

p { max-width: 66ch; }

/* ============================================================
   HERO
   ============================================================ */

.hero {
  position: relative;
  background: var(--asphalt);
  color: var(--paper);
  padding: clamp(56px, 9vw, 104px) clamp(20px, 5vw, 64px) clamp(48px, 7vw, 84px);
  overflow: hidden;
}
/* marcação rodoviária no fundo */
.hero::after {
  content: "";
  position: absolute;
  left: 0; right: 0; bottom: 26px;
  height: 14px;
  background: repeating-linear-gradient(
    90deg,
    var(--marking) 0 46px,
    transparent 46px 92px
  );
  opacity: .16;
}
.hero__inner { position: relative; max-width: var(--maxw); z-index: 2; }

.hero__sign {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  background: var(--park-blue);
  padding: 10px 18px 10px 12px;
  border-radius: 12px;
  box-shadow: inset 0 0 0 3px rgba(255,255,255,.22);
  margin-bottom: 26px;
}
.hero__sign-p {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 34px;
  color: #fff;
  line-height: 1;
}
.hero__sign-text {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: #DCE6FF;
  text-align: left;
  line-height: 1.4;
}

.hero h1 {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(38px, 7vw, 76px);
  letter-spacing: -.03em;
  line-height: .98;
  margin: 0 0 22px;
}
.hero h1 em {
  font-style: normal;
  color: var(--marking);
}
.hero__lead {
  font-size: clamp(17px, 2.2vw, 20px);
  color: #C9CED8;
  max-width: 56ch;
  margin: 0 0 30px;
}

.hero__route {
  display: flex;
  flex-wrap: wrap;
  gap: 10px 8px;
  font-family: var(--font-mono);
  font-size: 12.5px;
}
.hero__stop {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--asphalt-2);
  border: 1px solid var(--asphalt-3);
  padding: 7px 13px;
  border-radius: 999px;
  color: #DDE2EC;
}
.hero__stop b { color: var(--marking); font-weight: 700; }
.hero__arrow { color: var(--mute-2); align-self: center; }

/* ============================================================
   CARTÕES / GRELHAS GENÉRICAS
   ============================================================ */

.card {
  background: var(--paper-2);
  border: 1px solid var(--paper-line);
  border-radius: 14px;
  padding: 22px 22px;
}

.grid { display: grid; gap: 16px; }
.grid--2 { grid-template-columns: repeat(2, 1fr); }
.grid--3 { grid-template-columns: repeat(3, 1fr); }

/* ecrãs (interfaces) */
.screen {
  background: var(--paper-2);
  border: 1px solid var(--paper-line);
  border-radius: 14px;
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.screen__head {
  display: flex;
  align-items: center;
  gap: 10px;
}
.screen__no {
  font-family: var(--font-mono);
  font-size: 11px;
  background: var(--asphalt);
  color: var(--marking);
  padding: 3px 8px;
  border-radius: 6px;
}
.screen__name {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 15.5px;
}
.screen__desc { font-size: 14px; color: var(--mute); margin: 0; }

/* lista de passos / fluxo */
.flow {
  list-style: none;
  margin: 0; padding: 0;
  display: grid;
  gap: 10px;
  counter-reset: step;
}
.flow li {
  position: relative;
  background: var(--paper-2);
  border: 1px solid var(--paper-line);
  border-left: 4px solid var(--park-blue);
  border-radius: 10px;
  padding: 13px 16px 13px 52px;
  font-size: 15px;
}
.flow li::before {
  counter-increment: step;
  content: counter(step);
  position: absolute;
  left: 12px; top: 50%;
  transform: translateY(-50%);
  width: 26px; height: 26px;
  background: var(--park-blue);
  color: #fff;
  font-family: var(--font-mono);
  font-size: 13px;
  border-radius: 50%;
  display: grid;
  place-items: center;
}
.flow li b { color: var(--ink); }
.flow li .flow__task {
  display: inline-block;
  margin-left: 6px;
  font-family: var(--font-mono);
  font-size: 11.5px;
  color: var(--park-blue);
}

/* fluxo em linha (pílulas) */
.flowline {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono);
  font-size: 13px;
}
.flowline span {
  background: var(--paper-2);
  border: 1px solid var(--paper-line);
  padding: 6px 12px;
  border-radius: 999px;
}
.flowline i { color: var(--mute-2); font-style: normal; }

/* avaliadores */
.evaluator {
  background: var(--paper-2);
  border: 1px solid var(--paper-line);
  border-radius: 12px;
  padding: 16px 18px;
}
.evaluator__name {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 16px;
  margin-bottom: 2px;
}
.evaluator__role {
  font-size: 12.5px;
  color: var(--park-blue);
  font-weight: 600;
  margin-bottom: 8px;
}
.evaluator__desc { font-size: 13.5px; color: var(--mute); margin: 0 0 10px; }
.tasktags { display: flex; flex-wrap: wrap; gap: 5px; }
.tasktag {
  font-family: var(--font-mono);
  font-size: 11px;
  background: var(--asphalt);
  color: var(--marking);
  padding: 2px 7px;
  border-radius: 5px;
}

/* tabela de valores */
.table-wrap { overflow-x: auto; border-radius: 12px; border: 1px solid var(--paper-line); }
table.data {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
  min-width: 460px;
  background: var(--paper-2);
}
table.data th, table.data td {
  text-align: left;
  padding: 11px 14px;
  border-bottom: 1px solid var(--paper-line);
}
table.data thead th {
  background: var(--asphalt);
  color: var(--paper);
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: .05em;
  text-transform: uppercase;
}
table.data tbody tr:last-child td { border-bottom: 0; }
table.data .val { font-family: var(--font-mono); font-weight: 700; }
table.data .val--ok { color: var(--ok); }

/* listas de medidas */
.measures { display: grid; gap: 12px; counter-reset: m; }
.measure {
  position: relative;
  background: var(--paper-2);
  border: 1px solid var(--paper-line);
  border-radius: 12px;
  padding: 16px 18px 16px 56px;
}
.measure::before {
  counter-increment: m;
  content: counter(m, decimal-leading-zero);
  position: absolute;
  left: 16px; top: 16px;
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--marking);
  background: var(--asphalt);
  padding: 3px 7px;
  border-radius: 6px;
}
.measure h4 {
  font-family: var(--font-display);
  font-size: 15px;
  margin: 0 0 4px;
}
.measure p { font-size: 14px; color: var(--mute); margin: 0; }

/* nota / destaque */
.note {
  border-left: 4px solid var(--marking);
  background: #FBF7E8;
  border-radius: 0 10px 10px 0;
  padding: 14px 18px;
  font-size: 14.5px;
  color: var(--ink);
}
.note strong { color: var(--ink); }

/* ============================================================
   QUADRO DE PRINCÍPIOS (3.2 — foco)
   ============================================================ */

.focus-banner {
  background: var(--park-blue);
  color: #fff;
  border-radius: 14px;
  padding: 18px 22px;
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 26px;
  box-shadow: inset 0 0 0 3px rgba(255,255,255,.18);
}
.focus-banner__icon {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 24px;
  background: rgba(255,255,255,.16);
  width: 44px; height: 44px;
  display: grid; place-items: center;
  border-radius: 9px;
  flex: none;
}
.focus-banner p { margin: 0; color: #EAF0FF; font-size: 14.5px; max-width: none; }
.focus-banner b { color: var(--marking); }

.filters {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 8px;
}
.filter-tab {
  font-family: var(--font-mono);
  font-size: 12.5px;
  border: 1px solid var(--paper-line);
  background: var(--paper-2);
  color: var(--ink);
  padding: 8px 14px;
  border-radius: 999px;
  cursor: pointer;
  transition: background .15s, color .15s, border-color .15s;
}
.filter-tab:hover { border-color: var(--mute-2); }
.filter-tab.is-active {
  background: var(--asphalt);
  color: #fff;
  border-color: var(--asphalt);
}
#board-count {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--mute);
  margin: 12px 0 18px;
}

.board {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}

.bay {
  background: var(--paper-2);
  border: 1px solid var(--paper-line);
  border-radius: 14px;
  padding: 18px 18px 16px;
  display: flex;
  flex-direction: column;
  opacity: 0;
  transform: translateY(14px);
  transition: opacity .5s ease, transform .5s ease;
}
.bay.is-in { opacity: 1; transform: none; }

.bay__head {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}
.bay__code {
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: 12px;
  color: #fff;
  padding: 3px 9px;
  border-radius: 6px;
  background: var(--asphalt);
}
.bay__cat {
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: .04em;
  text-transform: uppercase;
  color: var(--mute-2);
}
.bay__title {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 18px;
  letter-spacing: -.01em;
  margin: 0 0 8px;
}
.bay__def { font-size: 14px; color: var(--mute); margin: 0 0 14px; }
.bay__ecras { margin-top: auto; }
.bay__ecras-label {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--mute-2);
  display: block;
  margin-bottom: 7px;
}
.bay__ecras-list { display: flex; flex-wrap: wrap; gap: 5px; }
.ecra-tag {
  font-size: 11.5px;
  background: var(--paper);
  border: 1px solid var(--paper-line);
  padding: 3px 8px;
  border-radius: 6px;
  color: var(--ink);
}

/* cores por categoria */
.cat-norman { background: var(--cat-norman); }
.cat-shneiderman { background: var(--cat-shneiderman); }
.cat-nielsen { background: var(--cat-nielsen); }
.cat-visual { background: var(--cat-visual); }

/* ============================================================
   FERRAMENTAS DE ESTUDO (flashcards + quiz)
   ============================================================ */

.tools-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22px;
  align-items: start;
}

.tool {
  background: var(--asphalt);
  color: var(--paper);
  border-radius: 16px;
  padding: 22px;
}
.tool__label {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--marking);
  margin-bottom: 4px;
}
.tool__title {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 20px;
  margin: 0 0 16px;
}

/* flashcard */
.flash {
  perspective: 1200px;
  margin-bottom: 14px;
}
.flash__inner {
  position: relative;
  width: 100%;
  min-height: 196px;
  transform-style: preserve-3d;
  transition: transform .5s;
  cursor: pointer;
}
.flash.is-flipped .flash__inner { transform: rotateY(180deg); }
.flash__face {
  position: absolute;
  inset: 0;
  backface-visibility: hidden;
  border-radius: 12px;
  padding: 20px;
  display: flex;
  flex-direction: column;
}
.flash__front { background: var(--asphalt-2); border: 1px solid var(--asphalt-3); }
.flash__back {
  background: var(--paper);
  color: var(--ink);
  transform: rotateY(180deg);
}
.flash__cat {
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: var(--mute-2);
}
.flash__code {
  align-self: flex-start;
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: 12px;
  color: #fff;
  padding: 3px 9px;
  border-radius: 6px;
  margin: 8px 0 14px;
}
.flash__front-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 24px;
  letter-spacing: -.01em;
  margin: auto 0;
}
.flash__back-def { font-size: 14.5px; margin: 8px 0 auto; }
.flash__hint {
  font-family: var(--font-mono);
  font-size: 10.5px;
  color: var(--mute-2);
  margin-top: 14px;
}
.flash__back .flash__hint { color: var(--mute); }

.flash-controls {
  display: flex;
  align-items: center;
  gap: 8px;
}
.flash-controls #flash-progress {
  font-family: var(--font-mono);
  font-size: 12px;
  color: #C9CED8;
  margin-left: auto;
}

.btn {
  font-family: var(--font-body);
  font-weight: 600;
  font-size: 14px;
  border: 0;
  border-radius: 9px;
  padding: 9px 16px;
  cursor: pointer;
  transition: transform .1s, background .15s, opacity .15s;
}
.btn:active { transform: translateY(1px); }
.btn--marking { background: var(--marking); color: var(--asphalt); }
.btn--marking:hover { background: var(--marking-2); }
.btn--ghost {
  background: var(--asphalt-3);
  color: var(--paper);
}
.btn--ghost:hover { background: #38404e; }
.btn--icon { padding: 9px 14px; }

/* quiz */
.quiz__intro p { color: #C9CED8; font-size: 14.5px; margin: 0 0 16px; }
.quiz__score {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--marking);
  margin-bottom: 12px;
}
.quiz__cat {
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--mute-2);
  margin-bottom: 6px;
}
.quiz__q {
  font-size: 15.5px;
  font-style: italic;
  color: var(--paper);
  margin: 0 0 16px;
  line-height: 1.5;
}
.quiz__options { display: grid; gap: 8px; margin-bottom: 14px; }
.quiz-option {
  font-family: var(--font-body);
  text-align: left;
  font-size: 14px;
  background: var(--asphalt-2);
  border: 1px solid var(--asphalt-3);
  color: var(--paper);
  padding: 11px 14px;
  border-radius: 9px;
  cursor: pointer;
  transition: background .15s, border-color .15s;
}
.quiz-option:hover:not(:disabled) { border-color: var(--marking); }
.quiz-option:disabled { cursor: default; }
.quiz-option.is-correct {
  background: rgba(28,157,99,.22);
  border-color: var(--ok);
  color: #BFF4D8;
}
.quiz-option.is-wrong {
  background: rgba(216,68,43,.2);
  border-color: var(--stop);
  color: #FFC9BE;
}
.quiz-feedback {
  font-family: var(--font-mono);
  font-size: 12.5px;
  min-height: 18px;
  margin-bottom: 10px;
}
.quiz-feedback.ok { color: var(--ok); }
.quiz-feedback.no { color: #FF8E7A; }

.quiz__result { text-align: center; padding: 12px 0; }
.quiz__result-score {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 44px;
  color: var(--marking);
  line-height: 1;
  margin: 4px 0 8px;
}
.quiz__result-msg { color: #C9CED8; font-size: 14.5px; margin: 0 0 18px; }

/* ============================================================
   RODAPÉ
   ============================================================ */

.footer {
  margin-left: var(--sidebar-w);
  background: var(--asphalt);
  color: var(--mute-2);
  padding: 40px clamp(20px, 5vw, 64px);
  border-top: 1px solid var(--asphalt-3);
}
.footer__inner {
  max-width: var(--maxw);
  font-family: var(--font-mono);
  font-size: 12.5px;
  line-height: 1.7;
}
.footer b { color: var(--paper); }
.footer .footer__mark { color: var(--marking); }

/* utilitário de revelação */
.reveal {
  opacity: 0;
  transform: translateY(16px);
  transition: opacity .6s ease, transform .6s ease;
}
.reveal.is-in { opacity: 1; transform: none; }

/* ============================================================
   RESPONSIVO
   ============================================================ */

@media (max-width: 980px) {
  .board { grid-template-columns: 1fr; }
  .tools-grid { grid-template-columns: 1fr; }
  .grid--3 { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 820px) {
  :root { --sidebar-w: 0px; }
  .nav-toggle { display: block; }
  .sidebar {
    width: 280px;
    transform: translateX(-100%);
    transition: transform .25s ease;
  }
  .sidebar.is-open { transform: translateX(0); box-shadow: 0 0 0 100vmax rgba(0,0,0,.5); }
  .main, .footer { margin-left: 0; }
  .grid--2, .grid--3 { grid-template-columns: 1fr; }
}

@media (max-width: 480px) {
  .section { padding: 52px 18px; }
  .hero { padding: 64px 18px 56px; }
  .focus-banner { flex-direction: column; align-items: flex-start; }
}
